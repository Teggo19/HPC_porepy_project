<?xml version="1.0" encoding="UTF-8" ?>
<precice-configuration>
  <log>
    <sink
      filter="%Severity% > debug and %Rank% = 0"
      format="---[precice] %ColorizedSeverity% %Message%"
      enabled="true" />
  </log>

  <profiling mode="fundamental" synchronize="false" />

  <data:scalar name="Velocity" />
  <data:scalar name="Force" />

  <mesh name="PorousMedia-mesh" dimensions="2">
    <use-data name="Velocity" />
    <use-data name="Force" />
  </mesh>

  <mesh name="FreeFlow-mesh" dimensions="2">
    <use-data name="Velocity" />
    <use-data name="Force" />
  </mesh>

  <participant name="PorousMedia">
    <export:vtu directory="precice-exports" />
    <provide-mesh name="PorousMedia-mesh" />
    <receive-mesh name="FreeFlow-mesh" from="FreeFlow" />
    <read-data name="Force" mesh="PorousMedia-mesh" />
    <write-data name="Velocity" mesh="PorousMedia-mesh" />
    <mapping:nearest-neighbor
      direction="read"
      from="FreeFlow-mesh"
      to="PorousMedia-mesh"
      constraint="consistent" />
  </participant>

  <participant name="FreeFlow">
    <export:vtu directory="precice-exports" />
    <receive-mesh name="PorousMedia-mesh" from="PorousMedia" />
    <provide-mesh name="FreeFlow-mesh" />
    <mapping:nearest-neighbor
      direction="read"
      from="PorousMedia-mesh"
      to="FreeFlow-mesh"
      constraint="consistent" />
    <read-data name="Velocity" mesh="FreeFlow-mesh" />
    <write-data name="Force" mesh="FreeFlow-mesh" />
  </participant>

  <m2n:sockets acceptor="PorousMedia" connector="FreeFlow" exchange-directory=".." />

  <coupling-scheme:serial-implicit>
    <time-window-size value="1" />
    <max-time value="1" />
    <min-iterations value="2" />
    <max-iterations value="30" />
    <participants first="PorousMedia" second="FreeFlow" />
    <exchange data="Velocity" mesh="PorousMedia-mesh" from="PorousMedia" to="FreeFlow" />
    <exchange data="Force" mesh="FreeFlow-mesh" from="FreeFlow" to="PorousMedia" />
    <relative-convergence-measure limit="1.0e-6" data="Velocity" mesh="PorousMedia-mesh" />
    <relative-convergence-measure limit="1.0e-6" data="Force" mesh="FreeFlow-mesh" />
    <absolute-convergence-measure limit="1.0e-9" data="Velocity" mesh="PorousMedia-mesh" />
    <absolute-convergence-measure limit="1.0e-9" data="Force" mesh="FreeFlow-mesh" />
    <acceleration:aitken>
      <data mesh="FreeFlow-mesh" name="Force" />
      <initial-relaxation value="0.5" />
    </acceleration:aitken>
  </coupling-scheme:serial-implicit>
</precice-configuration>
